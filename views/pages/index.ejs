<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GameHub - Play Together</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/pages/index.css">
</head>

<body>
    <!-- Header -->
    <header>
        <nav>
            <div class="logo">
                <i class="fas fa-gamepad"></i>
                <h2>GameHub</h2>
            </div>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/games">Games</a>
                <a href="/profile">Profile</a>
                <a href="/login" class="login-btn">Login</a>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main>
        <div class="welcome-card">
            <h1>Welcome to GameHub</h1>
            <p>Play two-player games online with friends</p>

            <!-- Main Options Grid -->
            <div class="options-grid">
                <!-- Games Option -->
                <a href="/games" class="option-card">
                    <i class="fas fa-chess-board"></i>
                    <span>Games</span>
                    <small>Play now</small>
                </a>

                <!-- Invitations Option -->
                <a href="/invitations" class="option-card">
                    <i class="fas fa-envelope"></i>
                    <span>Invitations</span>
                    <small>3 pending</small>
                </a>

                <!-- Find Friends Option -->
                <a href="/find-friends" class="option-card">
                    <i class="fas fa-user-friends"></i>
                    <span>Find Friends</span>
                    <small>Connect</small>
                </a>

                <!-- Profile Option -->
                <a href="/profile" class="option-card">
                    <i class="fas fa-user"></i>
                    <span>Profile</span>
                    <small>Your stats</small>
                </a>
            </div>

            <!-- Quick Stats -->
            <div class="quick-stats">
                <div class="stat">
                    <span class="stat-value">234</span>
                    <span class="stat-label">Online</span>
                </div>
                <div class="stat">
                    <span class="stat-value">12</span>
                    <span class="stat-label">Games</span>
                </div>
                <div class="stat">
                    <span class="stat-value">1.2k</span>
                    <span class="stat-label">Players</span>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div>&copy; 2024 GameHub. All rights reserved.</div>
            <div class="social-links">
                <a href="#"><i class="fab fa-twitter"></i></a>
                <a href="#"><i class="fab fa-discord"></i></a>
                <a href="#"><i class="fab fa-github"></i></a>
            </div>
        </div>
    </footer>
</body>

</html>