<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Board - GameHub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/gamespage/queAndAnsBoard.css">
</head>

<body>
    <!-- Game Board Main Content -->
    <main class="game-play-container">
        <div class="game-play-card">
            <!-- Game Code Flag - Only visible when isStarted is false -->
            <% if (!isStarted) { %>
                <div class="game-code-flag">
                    <i class="fas fa-key"></i>
                    <span>Game Code: <strong>
                            <%= gameCode %>
                        </strong></span>
                </div>
                <% } %>

                    <input type="hidden" id="gameCode" value="<%= gameCode %>">
                    <!-- Game Area -->
                    <div class="game-area">
                        <!-- Player 2 - Top Right (Flipped Upside Down) -->
                        <div class="player-top">
                            <div class="player2-container flipped">
                                <div class="player2-avatar">
                                    <i class="fas fa-user"></i>
                                </div>
                                <span class="player2-name">Player 2</span>
                            </div>
                        </div>

                        <!-- Circular Game Board Middle -->
                        <div class="game-middle">
                            <!-- Circular Board Container -->
                            <div class="circular-board">
                                <!-- Center Heading -->
                                <div class="board-heading">
                                    <h1>Q&A</h1>
                                </div>

                                <!-- Inner Circle of Squares (10 squares) -->
                                <div class="circle-container inner-circle">
                                    <div class="square" style="--index: 0;"></div>
                                    <div class="square" style="--index: 1;"></div>
                                    <div class="square" style="--index: 2;"></div>
                                    <div class="square" style="--index: 3;"></div>
                                    <div class="square" style="--index: 4;"></div>
                                    <div class="square" style="--index: 5;"></div>
                                    <div class="square" style="--index: 6;"></div>
                                    <div class="square" style="--index: 7;"></div>
                                    <div class="square" style="--index: 8;"></div>
                                    <div class="square" style="--index: 9;"></div>
                                </div>

                                <!-- Outer Circle of Squares (10 squares) -->
                                <div class="circle-container outer-circle">
                                    <div class="square" style="--index: 0;"></div>
                                    <div class="square" style="--index: 1;"></div>
                                    <div class="square" style="--index: 2;"></div>
                                    <div class="square" style="--index: 3;"></div>
                                    <div class="square" style="--index: 4;"></div>
                                    <div class="square" style="--index: 5;"></div>
                                    <div class="square" style="--index: 6;"></div>
                                    <div class="square" style="--index: 7;"></div>
                                    <div class="square" style="--index: 8;"></div>
                                    <div class="square" style="--index: 9;"></div>
                                </div>

                                <!-- Direction Arrows -->
                                <div class="direction-arrow top-arrow"></div>
                                <div class="direction-arrow bottom-arrow"></div>
                            </div>
                        </div>

                        <!-- Player 1 - Bottom Left (Vertical Layout) -->
                        <div class="player-bottom">
                            <div class="player1-container-vertical">
                                <div class="player1-avatar">
                                    <i class="fas fa-user"></i>
                                </div>
                                <span class="player1-name">You</span>

                                <!-- Emoji Button (Below player info) -->
                                <div class="emoji-button-container">
                                    <button class="emoji-btn" id="emojiBtn">
                                        <i class="far fa-smile"></i>
                                    </button>

                                    <!-- Emoji Picker -->
                                    <div class="emoji-picker" id="emojiPicker">
                                        <div class="emoji-option">😊</div>
                                        <div class="emoji-option">😂</div>
                                        <div class="emoji-option">😎</div>
                                        <div class="emoji-option">😍</div>
                                        <div class="emoji-option">👍</div>
                                        <div class="emoji-option">👏</div>
                                        <div class="emoji-option">🎉</div>
                                        <div class="emoji-option">🔥</div>
                                        <div class="emoji-option">⚡</div>
                                        <div class="emoji-option">💯</div>
                                        <div class="emoji-option">❓</div>
                                        <div class="emoji-option">💪</div>
                                        <div class="emoji-option">🎮</div>
                                        <div class="emoji-option">🎲</div>
                                        <div class="emoji-option">🏆</div>
                                        <div class="emoji-option">🎯</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Circular Back Button -->
                    <a href="/games" class="back-circle">
                        <i class="fas fa-arrow-left"></i>
                    </a>
        </div>
    </main>

    <!-- Question Input Modal -->
    <div class="question-modal-overlay" id="questionModalOverlay">
        <div class="question-modal">
            <div class="question-modal-header" style="text-align: center;">
                <h2>Your Turn! 🎯</h2>
            </div>
            <div class="question-modal-body">
                <p class="turn-message">It's your turn to ask a question!</p>
                <textarea id="questionInput" class="question-input-field" placeholder="Enter your question here..."
                    rows="4"></textarea>

                <!-- Options Inputs -->
                <div class="options-container">
                    <div class="option-row">
                        <input type="text" id="optionA" class="option-input" placeholder="Enter option A">
                        <input type="checkbox" id="checkboxA" class="option-checkbox">
                    </div>
                    <div class="option-row">
                        <input type="text" id="optionB" class="option-input" placeholder="Enter option B">
                        <input type="checkbox" id="checkboxB" class="option-checkbox">
                    </div>
                    <div class="option-row">
                        <input type="text" id="optionC" class="option-input" placeholder="Enter option C">
                        <input type="checkbox" id="checkboxC" class="option-checkbox">
                    </div>
                    <div class="option-row">
                        <input type="text" id="optionD" class="option-input" placeholder="Enter option D">
                        <input type="checkbox" id="checkboxD" class="option-checkbox">
                    </div>
                    <div class="mark-answer-text">mark the right answer</div>
                </div>

                <div class="modal-buttons">
                    <button class="btn-submit-question" id="submitQuestionBtn" disabled>Submit Question</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Include socket.io client library -->
    <script src="https://cdn.socket.io/4.5.4/socket.io.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>

    <script src="/js/socket.js"></script>

    <script>
        // ✅ Question Modal Event Listeners
        const submitQuestionBtn = document.getElementById('submitQuestionBtn');
        const questionModalOverlay = document.getElementById('questionModalOverlay');
        const questionInput = document.getElementById('questionInput');
        const optionInputs = [
            document.getElementById('optionA'),
            document.getElementById('optionB'),
            document.getElementById('optionC'),
            document.getElementById('optionD')
        ];
        const optionCheckboxes = [
            document.getElementById('checkboxA'),
            document.getElementById('checkboxB'),
            document.getElementById('checkboxC'),
            document.getElementById('checkboxD')
        ];

        // ✅ Validate all fields and enable/disable submit button
        function validateQuestionForm() {
            const question = questionInput.value.trim();
            const allOptionsEmpty = optionInputs.every(input => input.value.trim() === '');
            const atLeastOneChecked = optionCheckboxes.some(checkbox => checkbox.checked);

            // Check if question is empty or all options are empty or no checkbox selected
            if (!question || allOptionsEmpty || !atLeastOneChecked) {
                submitQuestionBtn.disabled = true;
                submitQuestionBtn.style.opacity = '0.5';
            } else {
                // Check if all individual options are filled
                const allOptionsFilled = optionInputs.every(input => input.value.trim() !== '');
                if (allOptionsFilled && atLeastOneChecked) {
                    submitQuestionBtn.disabled = false;
                    submitQuestionBtn.style.opacity = '1';
                } else {
                    submitQuestionBtn.disabled = true;
                    submitQuestionBtn.style.opacity = '0.5';
                }
            }
        }

        // ✅ Handle mutually exclusive checkboxes
        optionCheckboxes.forEach((checkbox) => {
            checkbox.addEventListener('change', (e) => {
                if (e.target.checked) {
                    // Uncheck all other checkboxes
                    optionCheckboxes.forEach((cb) => {
                        if (cb !== e.target) {
                            cb.checked = false;
                        }
                    });
                }
                validateQuestionForm();
            });
        });

        // Add validation listeners
        questionInput.addEventListener('input', validateQuestionForm);
        optionInputs.forEach(input => {
            input.addEventListener('input', validateQuestionForm);
        });

        submitQuestionBtn.addEventListener('click', submitQuestion);

        // Close modal when clicking outside
        questionModalOverlay.addEventListener('click', (e) => {
            if (e.target === questionModalOverlay) {
                hideQuestionModal();
            }
        });

        // Allow Enter key to submit question (Shift + Enter for new line)
        questionInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                submitQuestion();
            }
        });

        // Emoji picker functionality
        const emojiBtn = document.getElementById('emojiBtn');
        const emojiPicker = document.getElementById('emojiPicker');

        emojiBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            emojiPicker.classList.toggle('show');
        });

        // Close emoji picker when clicking outside
        document.addEventListener('click', (e) => {
            if (!emojiBtn.contains(e.target) && !emojiPicker.contains(e.target)) {
                emojiPicker.classList.remove('show');
            }
        });

        // Handle emoji selection
        document.querySelectorAll('.emoji-option').forEach(emoji => {
            emoji.addEventListener('click', () => {
                const selectedEmoji = emoji.textContent;
                console.log('Selected emoji:', selectedEmoji);

                // Emit websocket event for sending emoji
                const gameCodeInput = document.getElementById('gameCode');
                if (gameCodeInput && socket) {
                    socket.emit('sentEmoji', {
                        senderId: socket.id,
                        emoji: selectedEmoji,
                        gameCode: gameCodeInput.value
                    });
                }

                // Visual feedback
                emojiBtn.innerHTML = selectedEmoji;
                setTimeout(() => {
                    emojiBtn.innerHTML = '<i class="far fa-smile"></i>';
                }, 2000);

                emojiPicker.classList.remove('show');
            });
        });

        // Interactive control items
        document.querySelectorAll('.control-item').forEach(item => {
            item.addEventListener('click', () => {
                item.style.animation = 'pulse 0.5s';
                setTimeout(() => {
                    item.style.animation = '';
                }, 500);
            });
        });
    </script>

</body>

</html>